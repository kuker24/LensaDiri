# Public application origin only. Must be an origin with no path, query, or hash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local trusted PostgreSQL/Supabase URL. Replace every angle-bracket placeholder locally.
DATABASE_URL=postgresql://postgres:<LOCAL_SUPABASE_DB_PASSWORD>@127.0.0.1:54322/postgres

# Generate distinct local values with: openssl rand -hex 32
AUTH_SESSION_SECRET=<GENERATE_UNIQUE_64_HEX_CHAR_SECRET>
CSRF_SECRET=<GENERATE_UNIQUE_64_HEX_CHAR_SECRET>
TOKEN_HASH_PEPPER=<GENERATE_UNIQUE_64_HEX_CHAR_SECRET>
RATE_LIMIT_SECRET=<GENERATE_UNIQUE_64_HEX_CHAR_SECRET>

# Used only by real-PostgreSQL integration tests. Use local disposable database only.
TEST_DATABASE_URL=postgresql://postgres:<LOCAL_SUPABASE_DB_PASSWORD>@127.0.0.1:54322/postgres
